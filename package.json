{
  "name": "youtube-library",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run api & npm run dev",
    "launch": "npm run fetch-videos && git add . && git commit -m 'YT' && git push && npm run deploy",
    "push": "git add . && git commit -m 'YT' && git push && npm run deploy",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-videos": "node scripts/fetchVideos.js",
    "api": "node scripts/server.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-youtube": "^10.1.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "ytdl-core": "^4.11.5",
    "ytpl": "^2.3.0"
  }
}
